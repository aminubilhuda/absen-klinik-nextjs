generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  KARYAWAN
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum AttendanceStatus {
  TEPAT_WAKTU
  TERLAMBAT
}

enum LeaveType {
  IZIN
  SAKIT
  CUTI
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DayOfWeek {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

model User {
  id           String     @id @default(cuid())
  nama         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  noHp         String?    @map("no_hp")
  role         Role       @default(KARYAWAN)
  status       UserStatus @default(PENDING)
  image        String?
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  pushSubscriptions PushSubscription[]
  reviewedLeaves  LeaveRequest[]    @relation("ReviewedLeaves")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ClinicSetting {
  id          String  @id @default(cuid())
  latitude    Float
  longitude   Float
  radiusMeter Int     @map("radius_meter")
  namaKlinik  String  @map("nama_klinik")

  @@map("clinic_settings")
}

model WorkSchedule {
  id        String    @id @default(cuid())
  day       DayOfWeek @unique
  jamMasuk  String?   @map("jam_masuk")
  jamKeluar String?   @map("jam_keluar")
  isLibur   Boolean   @default(false) @map("is_libur")

  @@map("work_schedules")
}

model Attendance {
  id             String           @id @default(cuid())
  userId         String           @map("user_id")
  tanggal        DateTime         @db.Date
  waktuCheckin   DateTime?        @map("waktu_checkin")
  latCheckin     Float?           @map("lat_checkin")
  lngCheckin     Float?           @map("lng_checkin")
  jarakCheckin   Float?           @map("jarak_checkin")
  waktuCheckout  DateTime?        @map("waktu_checkout")
  latCheckout    Float?           @map("lat_checkout")
  lngCheckout    Float?           @map("lng_checkout")
  jarakCheckout  Float?           @map("jarak_checkout")
  status         AttendanceStatus
  menitTerlambat Int?             @map("menit_terlambat")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tanggal])
  @@map("attendances")
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String      @map("user_id")
  jenis        LeaveType
  tanggalMulai DateTime    @map("tanggal_mulai") @db.Date
  tanggalAkhir DateTime    @map("tanggal_akhir") @db.Date
  alasan       String      @db.Text
  lampiranUrl  String?     @map("lampiran_url")
  status       LeaveStatus @default(PENDING)
  catatanAdmin String?     @map("catatan_admin") @db.Text
  reviewedBy   String?     @map("reviewed_by")
  reviewedAt   DateTime?   @map("reviewed_at")
  createdAt    DateTime    @default(now()) @map("created_at")

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer   User? @relation("ReviewedLeaves", fields: [reviewedBy], references: [id])

  @@map("leave_requests")
}

model PushSubscription {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  endpoint  String @db.Text
  keys      String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}
