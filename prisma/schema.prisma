generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  KARYAWAN
  ADMIN
}

enum UserStatus {
  PENDING
  ACTIVE
  REJECTED
  DEACTIVATED
}

enum AttendanceStatus {
  TEPAT_WAKTU
  TERLAMBAT
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DayOfWeek {
  SENIN
  SELASA
  RABU
  KAMIS
  JUMAT
  SABTU
  MINGGU
}

model UnitKerja {
  id        String   @id @default(cuid())
  nama      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  users User[]

  @@map("unit_kerja")
}

model User {
  id           String     @id @default(cuid())
  nip          String?
  nama         String
  email        String     @unique
  passwordHash String     @map("password_hash")
  noHp         String?    @map("no_hp")
  role         Role       @default(KARYAWAN)
  status       UserStatus @default(PENDING)
  image        String?
  unitKerjaId  String?    @map("unit_kerja_id")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  unitKerja       UnitKerja?        @relation(fields: [unitKerjaId], references: [id])
  attendances     Attendance[]
  leaveRequests   LeaveRequest[]
  pushSubscriptions PushSubscription[]
  reviewedLeaves  LeaveRequest[]    @relation("ReviewedLeaves")

  accounts Account[]
  sessions Session[]

  @@index([role, status])
  @@index([unitKerjaId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model ClinicSetting {
  id          String  @id @default(cuid())
  latitude    Float
  longitude   Float
  radiusMeter Int     @map("radius_meter")
  namaKlinik  String  @map("nama_klinik")

  @@map("clinic_settings")
}

model WorkSchedule {
  id        String    @id @default(cuid())
  day       DayOfWeek @unique
  jamMasuk  String?   @map("jam_masuk")
  jamKeluar String?   @map("jam_keluar")
  isLibur   Boolean   @default(false) @map("is_libur")

  @@map("work_schedules")
}

model Attendance {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  tanggal           DateTime         @db.Date
  waktuCheckin      DateTime?        @map("waktu_checkin")
  latCheckin        Float?           @map("lat_checkin")
  lngCheckin        Float?           @map("lng_checkin")
  jarakCheckin      Float?           @map("jarak_checkin")
  waktuCheckout     DateTime?        @map("waktu_checkout")
  latCheckout       Float?           @map("lat_checkout")
  lngCheckout       Float?           @map("lng_checkout")
  jarakCheckout     Float?           @map("jarak_checkout")
  status            AttendanceStatus
  menitTerlambat    Int?             @map("menit_terlambat")
  kategoriAbsensiId String?          @map("kategori_absensi_id")
  fotoCheckin       String?          @map("foto_checkin")
  fotoCheckout      String?          @map("foto_checkout")

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  kategoriAbsensi KategoriAbsensi? @relation(fields: [kategoriAbsensiId], references: [id], onDelete: SetNull)

  @@unique([userId, tanggal])
  @@map("attendances")
}

model LeaveRequest {
  id               String             @id @default(cuid())
  userId           String             @map("user_id")
  kategoriAbsensiId String?            @map("kategori_absensi_id")
  tanggalMulai     DateTime           @map("tanggal_mulai") @db.Date
  tanggalAkhir     DateTime           @map("tanggal_akhir") @db.Date
  alasan           String             @db.Text
  lampiranUrl      String?            @map("lampiran_url")
  status           LeaveStatus        @default(PENDING)
  catatanAdmin     String?            @map("catatan_admin") @db.Text
  reviewedBy       String?            @map("reviewed_by")
  reviewedAt       DateTime?          @map("reviewed_at")
  createdAt        DateTime           @default(now()) @map("created_at")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer         User?             @relation("ReviewedLeaves", fields: [reviewedBy], references: [id], onDelete: SetNull)
  kategoriAbsensi  KategoriAbsensi?  @relation(fields: [kategoriAbsensiId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([userId])
  @@index([tanggalMulai, tanggalAkhir])
  @@map("leave_requests")
}

model HariLibur {
  id         String   @id @default(cuid())
  tanggal    DateTime @unique @db.Date
  keterangan String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("hari_libur")
}

model KategoriAbsensi {
  id         String   @id @default(cuid())
  kode       String   @unique
  keterangan String
  warnaLabel String?  @map("warna_label")
  isIzin     Boolean  @default(false) @map("is_izin")
  createdAt  DateTime @default(now()) @map("created_at")

  attendances  Attendance[]
  leaveRequests LeaveRequest[]

  @@map("kategori_absensi")
}

model PushSubscription {
  id           String @id @default(cuid())
  userId       String @map("user_id")
  endpoint     String @db.Text
  endpointHash String @map("endpoint_hash")
  keys         String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpointHash])
  @@map("push_subscriptions")
}
